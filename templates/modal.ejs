<div id="imageUploadModalError" class="popup" role="alertdialog" aria-modal="true" aria-labelledby="imageUploadModalErrorTitle">
  <div class="popup-content">
    <h2 id="imageUploadModalErrorTitle" class="error"></h2>
    <br>
    <button id="closeErrorModalButton">Close</button>
  </div>
</div>

<div id="imageUploadModalLoader" class="popup" role="status" aria-live="polite" aria-label="Uploading image">
  <div class="popup-content">
    <p class="loadingAnimation"></p>
  </div>
</div>
